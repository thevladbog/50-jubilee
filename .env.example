# ADMIN_SECRET: Shared secret used by the admin page and the admin API.
ADMIN_SECRET="МамеСнова18"

# PRESENTER_SECRET: opens the admin table in presenter mode.
# Presenter can only change wish reading status. Default in the app is "ЯВедущий".
PRESENTER_SECRET="ЯВедущий"

# Local SQLite file. Docker Compose overrides this to /data/rsvps.sqlite.
SQLITE_PATH="data/rsvps.sqlite"

# Docker Compose deployment settings.
DOMAIN="example.com"
ACME_EMAIL="admin@example.com"
APP_IMAGE="cr.yandex/<registry-id>/50-jubilee:latest"
